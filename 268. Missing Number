class Solution {
    public int missingNumber(int[] nums) {
        cyclic(nums);
        for(int i=0;i<nums.length;i++){
            if(nums[i]!=i){
                return i;
            }
        }
        return nums.length;
    }
    static void cyclic(int []nums){
        int i=0;
        while(i<nums.length){
            int correct=nums[i];
            if(nums[i]<nums.length && nums[i]!=nums[correct]){
                swap(nums,i, correct);
            }
            else{
                i++;
            }
        }
    }
    static void swap(int []nums, int start, int end){
        int temp=nums[start];
        nums[start]=nums[end];
        nums[end]=temp;
    }
}
